# Server Configuration
NODE_ENV=development
PORT=3000

# Application URLs
APP_URL=http://localhost:3000
VITE_APP_URL=http://localhost:3000
PUBLIC_APP_URL=https://aierpsystem-production.up.railway.app

# Application Branding (Optional)
VITE_APP_ID=ai_erp_system
VITE_APP_TITLE=AI ERP System
VITE_APP_LOGO=

# Database (MySQL 8+)
# For local: mysql://user:password@localhost:3306/ai_erp_system
# For Docker: mysql://erp_user:erp_password@db:3306/ai_erp_system
DATABASE_URL=mysql://user:password@localhost:3306/ai_erp_system

# Authentication
# Must be at least 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=your-secret-key-here-min-32-chars-change-this
OWNER_OPEN_ID=

# ============================================
# LLM / AI Configuration
# ============================================
# Supports Anthropic/Claude (default), OpenAI, or any OpenAI-compatible API.
# Provider is auto-detected from model name, or set LLM_PROVIDER explicitly.
#
# Anthropic / Claude (default):
#   LLM_PROVIDER=anthropic
#   LLM_API_KEY=sk-ant-your-anthropic-key
#   LLM_API_URL=          (leave empty, defaults to https://api.anthropic.com)
#   LLM_MODEL=claude-sonnet-4-20250514
#
# OpenAI:
#   LLM_PROVIDER=openai
#   LLM_API_KEY=sk-your-openai-key
#   LLM_API_URL=          (leave empty, defaults to https://api.openai.com)
#   LLM_MODEL=gpt-4o
#
# Kimi / Moonshot:
#   LLM_PROVIDER=openai
#   LLM_API_KEY=your-moonshot-key
#   LLM_API_URL=https://api.moonshot.cn
#   LLM_MODEL=moonshot-v1-128k
#
LLM_PROVIDER=anthropic
LLM_API_KEY=
LLM_API_URL=
LLM_MODEL=claude-sonnet-4-20250514

# Google OAuth & API (for Google Sheets/Drive integration)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_SHEETS_API_KEY=

# Email Configuration (IMAP - for inbox scanning)
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=

# SendGrid Email Service (for transactional emails)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_REPLY_TO=
SENDGRID_WEBHOOK_SECRET=

# QuickBooks OAuth & API
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=
QUICKBOOKS_ENVIRONMENT=sandbox

# Shopify OAuth & API
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_REDIRECT_URI=

# AWS S3 (for file storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=
