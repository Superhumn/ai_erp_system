# Server Configuration
NODE_ENV=development
PORT=3000

# Application URLs
APP_URL=http://localhost:3000
VITE_APP_URL=http://localhost:3000
PUBLIC_APP_URL=https://yourdomain.com

# Application Branding (Optional)
VITE_APP_ID=ai_erp_system
VITE_APP_TITLE=AI ERP System
VITE_APP_LOGO=

# Database (MySQL 8+)
# For local: mysql://user:password@localhost:3306/ai_erp_system
# For Docker: mysql://erp_user:erp_password@db:3306/ai_erp_system
DATABASE_URL=mysql://user:password@localhost:3306/ai_erp_system

# Authentication
# Must be at least 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=your-secret-key-here-min-32-chars-change-this
OWNER_OPEN_ID=

# ============================================
# LLM / AI Configuration
# ============================================
# Supports any OpenAI-compatible API: OpenAI, Kimi/Moonshot, Azure OpenAI, etc.
#
# OpenAI (default):
#   LLM_API_KEY=sk-your-openai-key
#   LLM_API_URL=          (leave empty, defaults to https://api.openai.com)
#   LLM_MODEL=gpt-4o
#
# Kimi / Moonshot:
#   LLM_API_KEY=your-moonshot-key
#   LLM_API_URL=https://api.moonshot.cn
#   LLM_MODEL=moonshot-v1-128k
#
# Azure OpenAI:
#   LLM_API_KEY=your-azure-key
#   LLM_API_URL=https://your-resource.openai.azure.com
#   LLM_MODEL=gpt-4o
#
LLM_API_KEY=
LLM_API_URL=
LLM_MODEL=gpt-4o

# Google OAuth & API (for Google Sheets/Drive integration)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_SHEETS_API_KEY=

# Email Configuration (IMAP - for inbox scanning)
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=

# SendGrid Email Service (for transactional emails)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_REPLY_TO=
SENDGRID_WEBHOOK_SECRET=

# QuickBooks OAuth & API
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=
QUICKBOOKS_ENVIRONMENT=sandbox

# Shopify OAuth & API
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_REDIRECT_URI=

# AWS S3 (for file storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=
