{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/dist/index.js" },
    { "source": "/webhooks/(.*)", "destination": "/dist/index.js" },
    { "source": "/(.*)", "destination": "/dist/index.js" }
  ],
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist"
}
